{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "LLDB",
            "type": "lldb",
            "request": "launch",
            "cwd": "${workspaceRoot}/build/Debug",
            "program": "${workspaceRoot}/build/Debug/venvpp2_example",
            "args": []
        },
        {
            "name": "GDB",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceRoot}/build/Debug/venvpp2_example",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceRoot}/build/Debug",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }

    ]
}
